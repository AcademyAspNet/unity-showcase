  _hints:
  - "\u041F\u0435\u0440\u0432\u0430\u044F \u0432\u0435\u0440\u0441\u0438\u044F \u0438\u0433\u0440\u043E\u0432\u043E\u0433\u043E
    \u0434\u0432\u0438\u0436\u043A\u0430 Unity \u0431\u044B\u043B\u0430 \u0441\u043E\u0437\u0434\u0430\u043D\u0430
    \u0432 2005 \u0433\u043E\u0434\u0443 \u043A\u043E\u043C\u043F\u0430\u043D\u0438\u0435\u0439
    Unity Technologies."
  - "\u041D\u0430\u0437\u0432\u0430\u043D\u0438\u0435 Unity (\u0432 \u043F\u0435\u0440\u0435\u0432\u043E\u0434\u0435
    \u0441 \u0430\u043D\u0433\u043B. \u2014 \xAB\u0435\u0434\u0438\u043D\u0441\u0442\u0432\u043E\xBB)
    \u0431\u044B\u043B\u043E \u0432\u044B\u0431\u0440\u0430\u043D\u043E \u043D\u0435
    \u0441\u043B\u0443\u0447\u0430\u0439\u043D\u043E \u2014 \u0433\u043B\u0430\u0432\u043D\u043E\u0439
    \u0438\u0434\u0435\u0435\u0439 \u0431\u044B\u043B\u043E \u043E\u0431\u044A\u0435\u0434\u0438\u043D\u0438\u0442\u044C
    \u0432\u0441\u0435 \u043F\u043B\u0430\u0442\u0444\u043E\u0440\u043C\u044B"
  - "\u0423\u043D\u0438\u0432\u0435\u0440\u0441\u0430\u043B\u044C\u043D\u044B\u0439
    \u043A\u043E\u043D\u0432\u0435\u0439\u0435\u0440 \u0440\u0435\u043D\u0434\u0435\u0440\u0438\u043D\u0433\u0430
    (URP) \u043E\u0431\u0435\u0441\u043F\u0435\u0447\u0438\u0432\u0430\u0435\u0442
    \u043E\u043F\u0442\u0438\u043C\u0430\u043B\u044C\u043D\u044B\u0439 \u0431\u0430\u043B\u0430\u043D\u0441
    \u043C\u0435\u0436\u0434\u0443 \u043A\u0430\u0447\u0435\u0441\u0442\u0432\u043E\u043C
    \u0433\u0440\u0430\u0444\u0438\u043A\u0438 \u0438 \u043F\u0440\u043E\u0438\u0437\u0432\u043E\u0434\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C\u044E"
